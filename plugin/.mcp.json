{
  "mcpServers": {
    "telegram_personal": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--project", "./mcp_server", "codex-telegram", "serve"],
      "env_vars": [
        "TG_API_ID",
        "TG_API_HASH",
        "CODEX_TELEGRAM_SESSION",
        "CODEX_TELEGRAM_MASTER_KEY"
      ],
      "cwd": "./",
      "startup_timeout_sec": 20,
      "tool_timeout_sec": 90
    }
  }
}
